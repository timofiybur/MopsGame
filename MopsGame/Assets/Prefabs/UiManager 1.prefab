  _data:
    _json: '{"declarations":{"Kind":"Object","collection":{"$content":[{"name":"RandomText","value":{"$content":["\u041d\u0435\u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e","\u043d\u0435\u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e","\u0425\u0430\u0445\u0430\u0445
      \u0431\u0440\u043e \u0440\u0456\u043b \u0434\u0443\u043c\u0430\u0454 \u0449\u043e
      \u0433\u0440\u0430 \u0431\u0443\u0434\u0435 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u0430
      \u043d\u0430 \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0430\u0445","\u0411\u0440\u043e...
      \u041d\u0435\u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e...","\u041d\u0435
      \u043d\u0430\u0442\u0438\u0441\u043a\u0430\u0439 \u0441\u044e\u0434\u0438","\u0413\u0440\u0430
      \u0454..... \u0442\u0456\u043b\u044c\u043a\u0438 \u043d\u0430 \u043a\u043e\u043c\u043f''\u044e\u0442\u0435\u0440\u0456","\u0411\u0440\u043e,
      \u0442\u0430\u043f\u0430\u0439 \u0431\u0456\u043b\u044c\u0448\u0435, \u043c\u043e\u0436\u0435
      \u043f\u043e\u0441\u0438\u043b\u0430\u043d\u043d\u044f \u043d\u0430 \u0433\u0440\u0443
      \u043e\u0442\u0440\u0438\u043c\u0430\u0454\u0448..","\u042f \u0437\u0430\u043d\u0430\u0434\u0442\u043e
      \u043b\u0456\u043d\u0438\u0432\u0438\u0439 \u0449\u043e\u0431 \u0440\u043e\u0431\u0438\u0442\u0438
      \u0433\u0440\u0443 \u043d\u0430 \u0442\u0435\u043b\u0435\u0444\u043e\u043d","\u0421\u043a\u0456\u043b\u044c\u043a\u0438
